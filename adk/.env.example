LLM_PROVIDER=vertex_ai
GEMINI_MODEL=gemini-2.5-flash
BEDROCK_MODEL_ID=eu.anthropic.claude-sonnet-4-5-20250929-v1:0
ORCHESTRATOR_MODEL=
SUB_AGENT_MODEL=

TINA_MCP_URL=
TINA_MCP_ENV=canary
TINA_MCP_INTERNAL=false
TINA_MCP_TIMEOUT_SECONDS=30
TINA_MCP_SSE_READ_TIMEOUT_SECONDS=300
TINA_MCP_BEARER_TOKEN=

# Cognito auth for Tina MCP.
# USER_PASSWORD_AUTH and ADMIN_USER_PASSWORD_AUTH use boto3.
# CLIENT_CREDENTIALS uses TINA_COGNITO_TOKEN_ENDPOINT with client_id/client_secret.
TINA_COGNITO_AUTH_FLOW=USER_PASSWORD_AUTH
TINA_COGNITO_CLIENT_ID=
TINA_COGNITO_CLIENT_SECRET=
TINA_COGNITO_USER_POOL_ID=
TINA_COGNITO_REGION=
TINA_COGNITO_USERNAME=
TINA_COGNITO_PASSWORD=
TINA_COGNITO_AUTH_ENDPOINT=
TINA_COGNITO_TOKEN_ENDPOINT=
TINA_COGNITO_JWKS_URL=
TINA_COGNITO_TOKEN_TYPE=access_token
TINA_COGNITO_SCOPES=
# Example: TINA_COGNITO_SCOPES=https://mcp.localhost/mcp/tools.read https://mcp.localhost/mcp/tools.write
TINA_COGNITO_TOKEN_REFRESH_MARGIN_SECONDS=300
