# Copy this file to .env for local Docker Compose usage.
# Keep real secrets out of git.

# ---------------------------------------------------------------------------
# Open WebUI authentication
# ---------------------------------------------------------------------------

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_ALLOWED_DOMAINS=example.com

# ---------------------------------------------------------------------------
# Postgres session backend
# ---------------------------------------------------------------------------

POSTGRES_DB=adk_sessions
POSTGRES_USER=adk
POSTGRES_PASSWORD=change-me

# ---------------------------------------------------------------------------
# Model provider
# Default is Bedrock. To switch to Gemini, set LLM_PROVIDER=vertex_ai and
# provide the Google/Vertex variables below.
#
# ORCHESTRATOR_MODEL and SUB_AGENT_MODEL are optional overrides:
# - Bedrock mode expects Bedrock model IDs.
# - Vertex mode expects Gemini model names.
# - Leave them blank to use provider defaults.
# ---------------------------------------------------------------------------

LLM_PROVIDER=bedrock
ORCHESTRATOR_MODEL=
SUB_AGENT_MODEL=

# Compatibility fallback for generic Bedrock callers. The orchestrator uses
# Claude Sonnet 4.6 by default and sub-agents use Claude Haiku 4.5 by default
# when the role-specific vars above are blank.
BEDROCK_MODEL_ID=eu.anthropic.claude-sonnet-4-6
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION_NAME=eu-central-1
AWS_DEFAULT_REGION=eu-central-1

# Vertex AI / Gemini mode.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=europe-west4
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/google-application-credentials.json
GEMINI_MODEL=gemini-2.5-flash
FALLBACK_REGIONS=europe-west4,europe-west9,europe-west3,europe-central1

# Optional direct Gemini API key for local experiments outside the Compose
# Vertex AI path.
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# LLM retry, rate limit, and history compaction controls
# ---------------------------------------------------------------------------

LLM_CALL_DELAY=3.0
LLM_RETRY_MAX_ATTEMPTS=6
LLM_RETRY_INITIAL_DELAY=10.0
LLM_RETRY_MAX_DELAY=120.0
LLM_RETRY_BACKOFF_FACTOR=2.0

ENABLE_HISTORY_COMPACTION=true
MAX_LLM_HISTORY_CONTENTS=32
MAX_LLM_HISTORY_CHARS=120000

# ---------------------------------------------------------------------------
# AWS cost integration
# For local Compose, ~/.aws is mounted into the platform-agent container.
# ---------------------------------------------------------------------------

AWS_PROFILE=
AWS_ACCOUNT_ALIASES=

# ---------------------------------------------------------------------------
# Hetzner cost integration
# ---------------------------------------------------------------------------

HETZNER_TOKEN=

# ---------------------------------------------------------------------------
# Local report output
# ---------------------------------------------------------------------------

REPORTS_DIR=/app/reports
AGENT_REPORTS_DIR=/app/reports
AGENT_BASE_DIR=/app

